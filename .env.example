# API key for the /api/scrape endpoint (set any secure value)
SCRAPE_API_KEY=your-secret-key-here

# Path to the SQLite database file
DATABASE_PATH=./data/inventory.db

# How often the cron job runs scrapes (in hours)
SCRAPE_INTERVAL_HOURS=4

# Algolia credentials for dealer inventory search (Peter Pan BMW, BMW of San Francisco)
ALGOLIA_APP_ID=your-algolia-app-id
ALGOLIA_API_KEY=your-algolia-api-key
